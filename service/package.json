{
  "name": "pdf-to-png-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Serverless PDF -> PNG conversion API (Hono + MuPDF). Deploys to Cloudflare Workers or any Node host.",
  "scripts": {
    "dev": "tsx watch src/node.ts",
    "start": "tsx src/node.ts",
    "deploy": "wrangler deploy",
    "cf:dev": "wrangler dev"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "jszip": "^3.10.1",
    "mupdf": "^1.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
